---
import BaseLayout from '../../layouts/BaseLayout.astro';
---
<BaseLayout title="Proyectos — jaosber" description="IoT, aprendizaje automático, webs, compiladores y más" breadcrumb={[{ label: "proyectos", href: "/projects/" }]}>
  
  <h1 class="page-title">Proyectos</h1>
  <p class="page-subtitle">IoT, aprendizaje automático, webs, compiladores y más.</p>

  <h2 class="section-title">IoT y Sistemas Embebidos</h2>
  <ul class="post-list">
    <li><a href="https://github.com/jaosber/esp32-hydrogen-monitor" target="_blank">
      <span class="post-date">ESP32 · Python · WebSocket</span>
      <span class="post-title">Monitor de Hidrógeno — Detección de gas en tiempo real con alarma remota</span>
    </a></li>
    <li><a href="https://github.com/jaosber/esp32cam-ap-stream" target="_blank">
      <span class="post-date">ESP32-CAM · Python · OpenCV</span>
      <span class="post-title">Cámara Inalámbrica — Transmisión de video en vivo por WiFi</span>
    </a></li>
  </ul>

  <h2 class="section-title">Aprendizaje Automático y Visión por Computador</h2>
  <ul class="post-list">
    <li><a href="https://github.com/jaosber/classroom-face-recognition" target="_blank">
      <span class="post-date">Python · RetinaFace · DeepFace</span>
      <span class="post-title">Reconocimiento Facial — Sistema de asistencia automática en aulas</span>
    </a></li>
    <li><a href="https://github.com/jaosber/mlp-latin-char-recognition" target="_blank">
      <span class="post-date">Python · Keras · Java</span>
      <span class="post-title">Reconocimiento de Caracteres — Red neuronal entrenada con 2700 fuentes</span>
    </a></li>
  </ul>

  <h2 class="section-title">Web</h2>
  <ul class="post-list">
    <li><a href="https://github.com/jaosber/djangochatwebsocket" target="_blank">
      <span class="post-date">Python · Django · Redis · WebSocket</span>
      <span class="post-title">Chat en Tiempo Real — Sala de chat con Django y WebSockets</span>
    </a></li>
  </ul>

  <h2 class="section-title">Compiladores y Análisis Sintáctico</h2>
  <ul class="post-list">
    <li><a href="https://github.com/jaosber/java-mysql-syntax" target="_blank">
      <span class="post-date">Java · ANTLR 4 · Swing</span>
      <span class="post-title">Analizador de SQL — Parser con visualización de árbol sintáctico</span>
    </a></li>
    <li><a href="https://github.com/jaosber/sql-lexical-analyzer" target="_blank">
      <span class="post-date">C · Flex</span>
      <span class="post-title">Analizador Léxico — Tokenizador para consultas SQL Server</span>
    </a></li>
    <li><a href="https://github.com/jaosber/flexbisoncalc" target="_blank">
      <span class="post-date">C · Flex · Bison</span>
      <span class="post-title">Calculadora con Parser — Operaciones matemáticas con análisis sintáctico</span>
    </a></li>
  </ul>

  <h2 class="section-title">Herramientas en Java</h2>
  <ul class="post-list">
    <li><a href="https://github.com/jaosber/java-regex-validator" target="_blank">
      <span class="post-date">Java · JLine</span>
      <span class="post-title">Validador de Datos — Verificación de emails, teléfonos, cédulas y fechas</span>
    </a></li>
    <li><a href="https://github.com/jaosber/java-prng-validator" target="_blank">
